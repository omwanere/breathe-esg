# Django Settings
DEBUG=True
SECRET_KEY=your-django-insecure-secret-key-change-this-in-production
# -----------------------------------------------
# LOCAL DEV (docker-compose — uses local postgres)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/breathedb_local

# LOCAL DEV (direct — connects to Supabase)
# DATABASE_URL=postgresql://postgres:[pass]@db.xxxx.supabase.co:5432/postgres?sslmode=require

# PRODUCTION (set in Render environment variables)
# DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# -----------------------------------------------
DATABASE_URL=sqlite:///db.sqlite3

# Frontend settings (in client container or local runtime environment)
VITE_API_URL=http://127.0.0.1:8000
